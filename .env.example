# Copy to .env.local and adjust for your environment.
# https://vitejs.dev/guide/env-and-mode.html

# Local backend (direct)
VITE_API_ROOT=http://localhost:3000

# Or use the Vite dev server origin so /api is proxied to localhost:3000
# VITE_API_ROOT=http://localhost:5173

# Multi-tenant style (production); subdomain comes from window.location.hostname
# VITE_API_PROTOCOL=https://
# VITE_API_DOMAIN=your-domain.com
